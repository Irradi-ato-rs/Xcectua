{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "xce-impact.schema.v1.json",
  "title": "Cross-Repo GCP Impact Analysis",
  "type": "object",
  "required": [
    "version",
    "gcp_file",
    "org",
    "referenced_governance_paths",
    "impacted_repositories",
    "generated_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "gcp_file": {
      "type": "string"
    },
    "org": {
      "type": "string"
    },
    "referenced_governance_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "impacted_repositories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}