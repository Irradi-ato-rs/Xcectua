{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "governance-org.schema.v1.json",
  "title": "Org-Wide Governance State",
  "type": "object",
  "required": ["version", "org", "generated_at", "repositories"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "org": {
      "type": "string",
      "description": "GitHub organization name"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "branch", "rer_doctor", "gov_diff"],
        "properties": {
          "repo": { "type": "string" },
          "branch": { "type": "string" },

          "rer_doctor": {
            "type": "object",
            "description": "Output of rer-doctor.sh",
            "additionalProperties": true
          },

          "gov_diff": {
            "type": "object",
            "description": "Output of gov-diff.sh",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
